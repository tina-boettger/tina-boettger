{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && node scripts/create-static-routes.mjs",
    "preview": "vite preview",
    "deploy:ftp": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-ftp.ps1",
    "deploy:ftp:dry-run": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-ftp.ps1 -WhatIf",
    "deploy:ftp:rollback": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-ftp.ps1",
    "ftp:archive-originals": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-ftp.ps1 -UploadOriginalMedia",
    "ftp:inspect-layout": "powershell -ExecutionPolicy Bypass -File ./scripts/inspect-ftp-layout.ps1",
    "ftp:setup-credential": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-ftp-credential.ps1",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
